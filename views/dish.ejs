<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= item.name %> | TableMint</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="min-h-screen bg-stone-50 text-stone-950">
    <%- include("partials/navbar") %>

    <main>
        <section class="mx-auto grid max-w-7xl gap-8 px-5 py-10 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:px-10">
            <div>
                <img src="<%= item.image %>" alt="<%= item.name %>" class="h-[420px] w-full rounded-lg object-cover shadow-sm">
            </div>
            <div class="flex flex-col justify-center">
                <a href="/menu" class="w-fit rounded-full border border-stone-300 px-4 py-2 text-sm font-bold text-stone-700 transition hover:border-stone-950 hover:text-stone-950">Back to menu</a>
                <p class="mt-8 text-sm font-bold uppercase tracking-[0.18em] text-emerald-700"><%= item.category %></p>
                <h1 class="mt-3 text-4xl font-black sm:text-5xl"><%= item.name %></h1>
                <p class="mt-5 text-lg leading-8 text-stone-600"><%= item.detail %></p>

                <div class="mt-6 grid gap-3 sm:grid-cols-3">
                    <div class="rounded-lg border border-stone-200 bg-white p-4">
                        <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Price</p>
                        <p class="mt-2 text-2xl font-black"><%= item.price %></p>
                    </div>
                    <div class="rounded-lg border border-stone-200 bg-white p-4">
                        <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Prep</p>
                        <p class="mt-2 text-2xl font-black"><%= item.prepTime %></p>
                    </div>
                    <div class="rounded-lg border border-stone-200 bg-white p-4">
                        <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Status</p>
                        <p class="mt-2 text-2xl font-black"><%= item.status %></p>
                    </div>
                </div>

                <div class="mt-6 flex flex-wrap gap-2">
                    <% item.tags.forEach((tag) => { %>
                        <span class="rounded-full bg-emerald-100 px-3 py-1 text-sm font-bold text-emerald-800"><%= tag %></span>
                    <% }) %>
                </div>

                <div class="mt-8 flex flex-wrap gap-3">
                    <a href="/reservation" class="rounded-full bg-stone-950 px-6 py-3 text-sm font-bold text-white transition hover:bg-emerald-700">Reserve a table</a>
                    <a href="/manage-menu" class="rounded-full border border-stone-300 px-6 py-3 text-sm font-bold text-stone-700 transition hover:border-stone-950 hover:text-stone-950">Manage item</a>
                </div>
            </div>
        </section>

        <section class="mx-auto max-w-7xl px-5 pb-12 sm:px-8 lg:px-10">
            <div class="flex items-end justify-between gap-4">
                <div>
                    <p class="text-sm font-bold text-emerald-700">More dishes</p>
                    <h2 class="mt-1 text-3xl font-black">Keep browsing</h2>
                </div>
                <a href="/menu" class="text-sm font-bold text-stone-700 hover:text-emerald-700">All menu</a>
            </div>
            <div class="mt-6 grid gap-5 md:grid-cols-3">
                <% menuItems.forEach((related) => { %>
                    <article class="rounded-lg border border-stone-200 bg-white shadow-sm">
                        <a href="/menu/<%= related.slug %>">
                            <img src="<%= related.image %>" alt="<%= related.name %>" class="h-36 w-full rounded-t-lg object-cover">
                        </a>
                        <div class="p-4">
                            <p class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-700"><%= related.category %></p>
                            <h3 class="mt-2 font-black"><a href="/menu/<%= related.slug %>" class="hover:text-emerald-700"><%= related.name %></a></h3>
                            <p class="mt-2 text-sm font-bold text-stone-500"><%= related.price %> · <%= related.prepTime %></p>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
    </main>

    <%- include("partials/footer") %>
</body>
</html>
