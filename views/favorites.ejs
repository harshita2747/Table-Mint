<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favorites | TableMint</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="min-h-screen bg-stone-50 text-stone-950">
    <%- include("partials/navbar") %>

    <main>
        <section class="bg-white">
            <div class="mx-auto max-w-7xl px-5 py-12 sm:px-8 lg:px-10">
                <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
                    <div>
                        <p class="text-sm font-bold text-emerald-700">Saved favorites</p>
                        <h1 class="mt-2 text-4xl font-black sm:text-5xl">Your favorite dishes</h1>
                        <p class="mt-4 max-w-2xl text-base leading-7 text-stone-600">Everything you've added — all in one place.</p>
                    </div>
                    <a href="/menu" class="w-fit rounded-full bg-stone-950 px-6 py-3 text-sm font-bold text-white transition hover:bg-emerald-700">Browse menu</a>
                </div>
            </div>
        </section>

        <section class="mx-auto max-w-7xl px-5 pb-12 sm:px-8 lg:px-10">
            <% if (favoriteItems.length === 0) { %>
                <div class="rounded-3xl border border-stone-200 bg-white p-10 text-center shadow-sm">
                    <p class="text-sm font-bold uppercase tracking-[0.18em] text-emerald-700">No favorites yet</p>
                    <h2 class="mt-4 text-3xl font-black">Start saving dishes from the menu.</h2>
                    <p class="mt-3 text-base leading-7 text-stone-600">When you add favorites, they will appear here in a responsive card layout.</p>
                    <a href="/menu" class="mt-8 inline-flex rounded-full bg-stone-950 px-6 py-3 text-sm font-bold text-white transition hover:bg-emerald-700">View menu</a>
                </div>
            <% } else { %>
                <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
                    <% favoriteItems.forEach((item) => { %>
                        <article class="rounded-lg border border-stone-200 bg-white shadow-sm">
                            <a href="/menu/<%= item.slug %>">
                                <img src="<%= item.image %>" alt="<%= item.name %>" class="h-48 w-full rounded-t-lg object-cover">
                            </a>
                            <div class="p-5">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-700"><%= item.category %></p>
                                        <h2 class="mt-2 text-xl font-black"><a href="/menu/<%= item.slug %>" class="hover:text-emerald-700"><%= item.name %></a></h2>
                                    </div>
                                    <p class="text-lg font-black"><%= item.price %></p>
                                </div>
                                <p class="mt-3 text-sm leading-6 text-stone-600"><%= item.description %></p>
                                <div class="mt-5 flex items-center justify-between text-sm font-bold text-stone-500">
                                    <span><%= item.prepTime %></span>
                                    <span class="rounded-full <%= item.status === 'Limited' ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800' %> px-3 py-1"><%= item.status %></span>
                                </div>
                                <form action="/favorite/delete/<%= item.id %>" method="POST" class="mt-5">
                                    <button type="submit" class="inline-flex w-full justify-center rounded-full border border-stone-300 bg-stone-950 px-4 py-2 text-sm font-bold text-white transition hover:bg-stone-800">Remove favorite</button>
                                </form>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>

    <%- include("partials/footer") %>
</body>
</html>
