<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reservation Confirmed | TableMint</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="min-h-screen bg-stone-50 text-stone-950">
    <%- include("partials/navbar") %>

    <main class="mx-auto max-w-4xl px-5 py-12 sm:px-8 lg:px-10">
        <section class="rounded-lg border border-stone-200 bg-white p-8 text-center shadow-sm">
            <p class="text-sm font-bold text-emerald-700">Reservation received</p>
            <h1 class="mt-2 text-4xl font-black sm:text-5xl">Your table is almost ready.</h1>
            <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-stone-600">This dummy flow shows the confirmation screen after a normal form post. In a real app, this is where you would save the booking and send a message.</p>

            <div class="mx-auto mt-8 grid max-w-2xl gap-3 text-left sm:grid-cols-2">
                <div class="rounded-lg bg-stone-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Name</p>
                    <p class="mt-2 font-black"><%= reservation.name || "Guest" %></p>
                </div>
                <div class="rounded-lg bg-stone-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Phone</p>
                    <p class="mt-2 font-black"><%= reservation.phone || "Not provided" %></p>
                </div>
                <div class="rounded-lg bg-stone-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Date</p>
                    <p class="mt-2 font-black"><%= reservation.date || "Tonight" %></p>
                </div>
                <div class="rounded-lg bg-stone-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Time</p>
                    <p class="mt-2 font-black"><%= reservation.time || "7:00 PM" %></p>
                </div>
                <div class="rounded-lg bg-stone-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Guests</p>
                    <p class="mt-2 font-black"><%= reservation.guests || "2 guests" %></p>
                </div>
                <div class="rounded-lg bg-stone-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-stone-500">Table</p>
                    <p class="mt-2 font-black"><%= reservation.table || "Indoor dining" %></p>
                </div>
            </div>

            <div class="mt-8 flex flex-wrap justify-center gap-3">
                <a href="/menu" class="rounded-full bg-stone-950 px-6 py-3 text-sm font-bold text-white transition hover:bg-emerald-700">Browse menu</a>
                <a href="/reservation" class="rounded-full border border-stone-300 px-6 py-3 text-sm font-bold text-stone-700 transition hover:border-stone-950 hover:text-stone-950">Edit reservation</a>
            </div>
        </section>
    </main>

    <%- include("partials/footer") %>
</body>
</html>
