<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TableMint | Restaurant Home</title>
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="min-h-screen bg-stone-50 text-stone-950">
    <main>
        <section class="relative overflow-hidden bg-stone-950 text-white">
            <img
                src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?auto=format&fit=crop&w=1800&q=80"
                alt="Chef plating a restaurant dish"
                class="absolute inset-0 h-full w-full object-cover opacity-45"
            >
            <div class="absolute inset-0 bg-linear-to-r from-stone-950 via-stone-950/80 to-stone-950/25"></div>

            <div class="relative mx-auto flex min-h-[600px] max-w-7xl flex-col px-5 py-6 sm:px-8 lg:px-10">
                <nav class="flex items-center justify-between gap-4">
                    <a href="/" class="flex items-center gap-3">
                        <span class="grid size-11 place-items-center rounded-full bg-emerald-400 text-lg font-black text-stone-950">T</span>
                        <span>
                            <span class="block text-lg font-bold leading-none">TableMint</span>
                            <span class="block text-xs font-medium text-stone-300">Modern restaurant</span>
                        </span>
                    </a>
                    <div class="hidden items-center gap-2 rounded-full border border-white/15 bg-white/10 p-1 text-sm font-semibold text-stone-200 backdrop-blur md:flex">
                        <a href="/menu" class="rounded-full px-4 py-2 transition hover:bg-white/10">Menu</a>
                        <a href="/reservation" class="rounded-full px-4 py-2 transition hover:bg-white/10">Reserve</a>
                        <a href="/manage-menu" class="rounded-full px-4 py-2 transition hover:bg-white/10">Manage</a>
                        <a href="/favorites" class="rounded-full px-4 py-2 transition hover:bg-white/10">Favorites</a>

                    </div>
                    <a href="/reservation" class="rounded-full bg-emerald-400 px-5 py-2.5 text-sm font-bold text-stone-950 shadow-lg shadow-emerald-950/30 transition hover:bg-emerald-300">Book table</a>
                </nav>

                <div class="flex flex-1 items-end pb-10 pt-24">
                    <div class="max-w-4xl">
                        <p class="mb-4 inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-semibold text-emerald-100 backdrop-blur">Open for dinner service tonight</p>
                        <h1 class="text-5xl font-black tracking-normal text-white sm:text-6xl lg:text-7xl">Fresh plates, fast reservations, and a clean restaurant flow.</h1>
                        <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-200">From cravings to reservations — all in one place.</p>
                        <div class="mt-8 flex flex-wrap gap-3">
                            <a href="/menu" class="rounded-full bg-white px-6 py-3 text-sm font-bold text-stone-950 transition hover:bg-emerald-100">Browse menu</a>
                            <a href="/reservation" class="rounded-full border border-white/25 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/10">Reserve table</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="mx-auto max-w-7xl px-5 py-12 sm:px-8 lg:px-10">
            <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <p class="text-sm font-bold text-emerald-700">Featured menu</p>
                    <h2 class="mt-1 text-3xl font-black sm:text-4xl">Guest-ready dishes</h2>
                </div>
                <a href="/menu" class="w-fit rounded-full border border-stone-300 px-5 py-2.5 text-sm font-bold text-stone-700 transition hover:border-stone-950 hover:text-stone-950">See full menu</a>
            </div>

            <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
                <% menuItems.forEach((item) => { %>
                    <article class="rounded-lg border border-stone-200 bg-white shadow-sm">
                        <div class="relative">
                            <a href="/menu/<%= item.slug %>">
                            <img src="<%= item.image %>" alt="<%= item.name %>" class="h-44 w-full rounded-t-lg object-cover">
                        </a>
                        <form action="/favorite/<%= item.id %>" method="POST">
                        <button
                            class="absolute top-3 right-3 w-10 h-10 flex items-center justify-center bg-white rounded-full shadow text-2xl <%= favoriteIds.includes(Number(item.id)) ? 'text-red-500' : 'text-stone-400' %>">
                            <%= favoriteIds.includes(Number(item.id)) ? "♥" : "♡" %>
                            </button>
                        </form>
                        </div>
                        <div class="p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-700"><%= item.category %></p>
                                    <h3 class="mt-2 text-xl font-black"><a href="/menu/<%= item.slug %>" class="hover:text-emerald-700"><%= item.name %></a></h3>
                                </div>
                                <p class="text-lg font-black"><%= item.price %></p>
                            </div>
                            <p class="mt-3 text-sm leading-6 text-stone-600"><%= item.description %></p>
                            <div class="mt-5 flex items-center justify-between text-sm font-bold text-stone-500">
                                <span><%= item.prepTime %></span>
                                <span class="rounded-full <%= item.status === 'Limited' ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800' %> px-3 py-1"><%= item.status %></span>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
    </main>

    <%- include("partials/footer") %>
</body>
</html>
